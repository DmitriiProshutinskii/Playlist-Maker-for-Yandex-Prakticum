<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingStart="13dp"
    android:paddingEnd="12dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp"
    android:gravity="center"
    >

    <ImageView
        android:id="@+id/track_image"
        android:layout_width="45dp"
        android:layout_height="45dp"
        android:layout_marginEnd="8dp"
        />
    <LinearLayout
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        >
        <TextView
            android:id="@+id/track_name"
            style="@style/TrackTitle"
            android:text="Yesterday"/>
        <Space android:layout_width="wrap_content" android:layout_height="1dp"/>
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            >
            <TextView
                android:id="@+id/track_artist"
                style="@style/TrackSubtitle"
                android:text="The Beatles"/>
            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:padding="5dp"
                android:src="@drawable/ic_dot"
                android:textColor="@color/onSurfaceMuted"
                android:contentDescription="@null" />
            <TextView
                android:id="@+id/track_time"
                style="@style/TrackSubtitle"
                android:text="2:55" />
        </LinearLayout>
    </LinearLayout>
    <ImageView
        android:layout_height="24dp"
        android:layout_width="24dp"
        android:layout_marginStart="8dp"
        android:id="@+id/track_chevron_right"
        android:src="@drawable/ic_chevron_right_24">
    </ImageView>


</LinearLayout>