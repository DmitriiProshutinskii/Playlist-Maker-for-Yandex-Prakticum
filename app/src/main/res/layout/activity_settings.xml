<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:background="@color/surface"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".SettingsActivity">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/settings_toolbar"
        style="@style/PlaylistToolbar"
        app:navigationIcon="@drawable/arrow_back"
        app:title="@string/settings"/>

    <com.google.android.material.switchmaterial.SwitchMaterial
        style="@style/SettingsLine"
        android:checked="true"
        android:text="@string/dark_theme"
        app:thumbTint="@color/thumbTint"
        app:trackTint="@color/trackTint" />

    <com.google.android.material.textview.MaterialTextView
        style="@style/SettingsLine"
        android:drawableEnd="@drawable/share"
        android:text="@string/share_app" />

    <com.google.android.material.textview.MaterialTextView
        style="@style/SettingsLine"
        android:drawableEnd="@drawable/support"
        android:text="@string/write_to_support" />

    <com.google.android.material.textview.MaterialTextView
        style="@style/SettingsLine"
        android:drawableEnd="@drawable/chevron_right"
        android:text="@string/terms_of_use" />
</LinearLayout>