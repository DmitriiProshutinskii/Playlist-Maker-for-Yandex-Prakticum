<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".SettingsActivity">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/settings_toolbar"
        style="@style/PlaylistToolbar"
        app:navigationIcon="@drawable/arrow_back"
        app:title="@string/setting_title"/>

    <com.google.android.material.switchmaterial.SwitchMaterial
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:checked="true"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="20dp"
        android:text="@string/dark_theme"
        android:fontFamily="@font/ys_display_regular"
        android:textColor="@color/black"
        android:textColorHighlight="@color/black"
        app:thumbTint="@color/thumbTint"
        app:trackTint="@color/trackTint"
        android:textSize="16sp" />

    <com.google.android.material.textview.MaterialTextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:drawableEnd="@drawable/share"
        android:paddingHorizontal="16dp"
        android:paddingVertical="20dp"
        android:text="@string/share_app"
        android:fontFamily="@font/ys_display_regular"
        android:textColor="@color/black"
        android:textSize="16sp" />

    <com.google.android.material.textview.MaterialTextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:drawableEnd="@drawable/support"
        android:paddingHorizontal="16dp"
        android:paddingVertical="20dp"
        android:text="@string/write_to_support"
        android:fontFamily="@font/ys_display_regular"
        android:textColor="@color/black"
        android:textSize="16sp" />

    <com.google.android.material.textview.MaterialTextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:drawableEnd="@drawable/chevron_right"
        android:paddingHorizontal="16dp"
        android:paddingVertical="20dp"
        android:text="@string/terms_of_use"
        android:fontFamily="@font/ys_display_regular"
        android:textColor="@color/black"
        android:textSize="16sp" />
</LinearLayout>