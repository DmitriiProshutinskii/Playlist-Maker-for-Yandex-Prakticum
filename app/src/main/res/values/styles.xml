<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="MainScreenButton" parent="Widget.MaterialComponents.Button.UnelevatedButton">
        <item name="android:insetBottom">16dp</item>
        <item name="android:insetRight">16dp</item>
        <item name="android:insetLeft">16dp</item>
        <item name="android:textAlignment">center</item>
        <item name="android:textColor">@color/YPBlack</item>
        <item name="android:textSize">22sp</item>
        <item name="backgroundTint">@color/YPWhite</item>
        <item name="android:fontFamily">@font/ys_display_medium</item>
        <item name="iconGravity">textStart</item>
        <item name="iconSize">24dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="iconTint">@color/YPBlack</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">0dp</item>
        <item name="android:layout_weight">1</item>
        <item name="iconPadding">8dp</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:letterSpacing">0</item>
        <item name="elevation">0dp</item>

    </style>
    <style name="PlaylistToolbar" parent="Widget.MaterialComponents.Toolbar">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">56dp</item>
        <item name="fontFamily">@font/ys_display_medium</item>
        <item name="android:textSize">22sp</item>
        <item name="titleTextColor">@color/onSurface</item>
    </style>
    <style name="SettingsLine">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingHorizontal">16dp</item>
        <item name="android:paddingVertical">20dp</item>
        <item name="android:fontFamily">@font/ys_display_regular</item>
        <item name="android:textColor">@color/settingsText</item>
        <item name="android:textSize">16sp</item>
    </style>
</resources>