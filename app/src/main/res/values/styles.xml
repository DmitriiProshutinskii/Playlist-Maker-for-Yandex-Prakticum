<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="MainScreenButton" parent="TextAppearance.MaterialComponents.Button">
        <item name="android:insetBottom">16dp</item>
        <item name="android:insetRight">16dp</item>
        <item name="android:insetLeft">16dp</item>
        <item name="android:textAlignment">center</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">22sp</item>
        <item name="backgroundTint">@color/white</item>
        <item name="android:fontFamily">@font/ys_display_medium</item>
        <item name="iconGravity">textStart</item>
        <item name="iconSize">24dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="iconTint">@color/black</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">0dp</item>
        <item name="android:layout_weight">1</item>
        <item name="iconPadding">8dp</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:letterSpacing">0</item>

    </style>
    <style name="PlaylistToolbar" parent="Widget.MaterialComponents.Toolbar">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">56dp</item>
        <item name="android:layout_gravity">start</item>
        <item name="android:layout_marginEnd">52dp</item>
        <item name="android:layout_marginBottom">24dp</item>
        <item name="android:paddingStart">4dp</item>
        <item name="android:paddingTop">4dp</item>
        <item name="android:paddingEnd">52dp</item>
        <item name="android:paddingBottom">4dp</item>
        <item name="fontFamily">@font/ys_display_medium</item>
        <item name="titleTextColor">@color/black</item>
    </style>
    <style name="SettingsLine">

    </style>
</resources>